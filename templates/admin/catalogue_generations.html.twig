{% extends 'base.html.twig' %}

{% block pageTitle %}Générations — {{ modele.nom }}{% endblock %}

{% block main %}
<div class="max-w-6xl mx-auto px-6 py-8">

    {% for msg in app.flashes('success') %}
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">{{ msg }}</div>
    {% endfor %}

    <div class="flex items-center justify-between mb-2">
        <div>
            <p class="text-sm text-tertiary mb-1">
                <a href="{{ path('admin_catalogue') }}" class="hover:text-primary transition-colors">Catalogue</a>
                <span class="mx-1">›</span>
                <a href="{{ path('admin_catalogue_modeles', {id: modele.id_marque}) }}" class="hover:text-primary transition-colors">{{ modele.marque_nom }}</a>
                <span class="mx-1">›</span>
                <span>{{ modele.nom }}</span>
            </p>
            <h1 class="text-3xl font-bold text-primary font-['ManRope']">{{ modele.marque_nom }} {{ modele.nom }} — Générations</h1>
            <p class="text-tertiary mt-1">{{ generations|length }} génération{{ generations|length != 1 ? 's' : '' }}</p>
        </div>
        <a href="{{ path('admin_catalogue_modeles', {id: modele.id_marque}) }}" class="text-sm text-tertiary hover:text-primary transition-colors">← Modèles</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">

        {# Formulaire d'ajout #}
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-sm p-6 sticky top-6">
                <h2 class="font-bold text-primary mb-1">Ajouter une génération</h2>
                <p class="text-xs text-gray-400 mb-4">Pour <span class="font-semibold">{{ modele.marque_nom }} {{ modele.nom }}</span></p>
                <form action="{{ path('admin_ajouter_generation', {id: modele.id_modele}) }}" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Nom / libellé</label>
                        <input type="text" name="nom" required
                               placeholder="Ex : Phase 1, MK4…"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Date de sortie</label>
                        <input type="date" name="date_sortie"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
                    </div>
                    <button type="submit"
                            class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-opacity-90 active:scale-[0.98] transition-all">
                        Ajouter
                    </button>
                </form>
            </div>
        </div>

        {# Liste des générations #}
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                {% if generations is empty %}
                    <div class="text-center py-16 text-gray-400">Aucune génération pour ce modèle.</div>
                {% else %}
                    <ul class="divide-y divide-gray-50">
                        {% for g in generations %}
                        <li class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors">
                            <div>
                                <p class="font-semibold text-primary">{{ g.nom ?: '(sans nom)' }}</p>
                                <p class="text-xs text-gray-400 mt-0.5">
                                    {% if g.date_sortie %}{{ g.date_sortie|date('Y') }}{% else %}Année inconnue{% endif %}
                                    — {{ g.nb_versions }} version{{ g.nb_versions != 1 ? 's' : '' }}
                                </p>
                            </div>
                            <div class="flex items-center gap-2">
                                <a href="{{ path('admin_catalogue_versions', {id: g.id_generation}) }}"
                                   class="px-3 py-1.5 border border-primary text-primary text-xs font-semibold rounded-lg hover:bg-primary hover:text-white transition-all">
                                    Versions →
                                </a>
                                <form action="{{ path('admin_supprimer_generation', {id: g.id_generation}) }}" method="post"
                                      onsubmit="return confirm('Supprimer la génération {{ g.nom }} ?')">
                                    <button type="submit"
                                            class="px-3 py-1.5 border border-red-300 text-red-500 text-xs font-semibold rounded-lg hover:bg-red-50 transition-all">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>

    </div>

</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block pageTitle %}Modèles — {{ marque.nom }}{% endblock %}

{% block main %}
<div class="max-w-6xl mx-auto px-6 py-8">

    {% for msg in app.flashes('success') %}
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">{{ msg }}</div>
    {% endfor %}

    <div class="flex items-center justify-between mb-2">
        <div>
            <p class="text-sm text-tertiary mb-1">
                <a href="{{ path('admin_catalogue') }}" class="hover:text-primary transition-colors">Catalogue</a>
                <span class="mx-1">›</span>
                <span>{{ marque.nom }}</span>
            </p>
            <h1 class="text-3xl font-bold text-primary font-['ManRope']">{{ marque.nom }} — Modèles</h1>
            <p class="text-tertiary mt-1">{{ modeles|length }} modèle{{ modeles|length != 1 ? 's' : '' }}</p>
        </div>
        <a href="{{ path('admin_catalogue') }}" class="text-sm text-tertiary hover:text-primary transition-colors">← Marques</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">

        {# Formulaire d'ajout #}
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-sm p-6 sticky top-6">
                <h2 class="font-bold text-primary mb-1">Ajouter un modèle</h2>
                <p class="text-xs text-gray-400 mb-4">Pour la marque <span class="font-semibold">{{ marque.nom }}</span></p>
                <form action="{{ path('admin_ajouter_modele', {id: marque.id_marque}) }}" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wider">Nom</label>
                        <input type="text" name="nom" required
                               placeholder="Ex : Clio, Golf, 308…"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
                    </div>
                    <button type="submit"
                            class="w-full py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-opacity-90 active:scale-[0.98] transition-all">
                        Ajouter
                    </button>
                </form>
            </div>
        </div>

        {# Liste des modèles #}
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                {% if modeles is empty %}
                    <div class="text-center py-16 text-gray-400">Aucun modèle pour cette marque.</div>
                {% else %}
                    <ul class="divide-y divide-gray-50">
                        {% for mo in modeles %}
                        <li class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors">
                            <div>
                                <p class="font-semibold text-primary">{{ mo.nom }}</p>
                                <p class="text-xs text-gray-400 mt-0.5">{{ mo.nb_generations }} génération{{ mo.nb_generations != 1 ? 's' : '' }}</p>
                            </div>
                            <div class="flex items-center gap-2">
                                <a href="{{ path('admin_catalogue_generations', {id: mo.id_modele}) }}"
                                   class="px-3 py-1.5 border border-primary text-primary text-xs font-semibold rounded-lg hover:bg-primary hover:text-white transition-all">
                                    Générations →
                                </a>
                                <form action="{{ path('admin_supprimer_modele', {id: mo.id_modele}) }}" method="post"
                                      onsubmit="return confirm('Supprimer le modèle {{ mo.nom }} ?')">
                                    <button type="submit"
                                            class="px-3 py-1.5 border border-red-300 text-red-500 text-xs font-semibold rounded-lg hover:bg-red-50 transition-all">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>

    </div>

</div>
{% endblock %}
